# Resend API key — used to deliver the Request a Quote form to email.
# Sign up: https://resend.com — verify a sender domain (or use the default)
# and paste the API key below.
RESEND_API_KEY=

# Inbox that receives quote enquiries.
QUOTE_EMAIL_TO=sales@arrowindustries.com.au

# Sender address used in the "From" header. Must be on a domain verified
# inside the Resend dashboard (or use Resend's default onboarding sender).
QUOTE_EMAIL_FROM=website@arrowindustries.com.au

# Public site URL (used for canonical, OG, sitemap).
NEXT_PUBLIC_SITE_URL=https://arrowindustries.com.au

# Instagram Graph API — long-lived access token for the Arrow Industries
# Business account. Used by the gallery's "Latest from Instagram" strip.
#
# In production this is a bootstrap value: the canonical token lives in
# Upstash/Vercel KV under `instagram:access_token`, refreshed weekly by the
# /api/cron/refresh-instagram-token cron job. Once the cron has run once,
# this env var is no longer read.
#
# Leave blank in dev if you don't want the strip — it'll render nothing.
INSTAGRAM_ACCESS_TOKEN=

# Upstash Redis (or Vercel KV — same thing under the hood). Connect via the
# Vercel Marketplace; either KV_REST_API_URL/TOKEN or UPSTASH_REDIS_REST_URL/TOKEN
# pairs work. Used to persist the rotating Instagram token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Shared secret Vercel sends in the Authorization header on cron requests.
# Set in Vercel Project Settings → Environment Variables. Generate with:
#   openssl rand -hex 32
CRON_SECRET=
